<%# locals: (alliances:, corporations:, characters:) %>

<%= turbo_frame_tag "search" do %>
  <% if alliances.any? %>
    <div class="col-12 col-sm-12 col-md-6 col-lg-4 col-xl-4">
      <h4 class="text-center text-break">Alliances</h4>

      <table id="alliances" class="table table-dark table-striped table-bordered">
        <thead>
          <tr>
            <th colspan="2" class="text-center">Name</th>
            <th class="text-center">Ticker</th>
            <th class="text-end">Corps</th>
            <th class="text-end">Members</th>
          </tr>
        </thead>

        <tbody>
          <%= render alliances %>
        </tbody>
      </table>
    </div>
  <% end %>

  <% if corporations.any? %>
    <div class="col-12 col-sm-12 col-md-6 col-lg-4 col-xl-4">
      <h4 class="text-center text-break">Corporations</h4>

      <table id="corporations" class="table table-dark table-striped table-bordered">
        <thead>
          <tr>
            <th colspan="2" class="text-center">Name</th>
            <th class="text-end">Members</th>
          </tr>
        </thead>

        <tbody>
          <%= render corporations %>
        </tbody>
      </table>
    </div>
  <% end %>

  <% if characters.any? %>
    <div class="col-12 col-sm-12 col-md-6 col-lg-4 col-xl-4">
      <h4 class="text-center text-break">Characters</h4>

      <table id="characters" class="table table-dark table-striped table-bordered">
        <thead>
          <tr>
            <th colspan="2" class="text-center">Name</th>
          </tr>
        </thead>

        <tbody>
          <%= render characters %>
        </tbody>
      </table>
    </div>
  <% end %>
<% end %>
